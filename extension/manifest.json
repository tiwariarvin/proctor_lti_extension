{
  "manifest_version": 3,
  "name": "D2L LTI quiz tab proctor",
  "version": "0.1.0",
  "description": "Controls a Brightspace quiz tab opened from the proctor LTI tool (Play, Pause, Stop/close).",
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-lti-bridge.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
