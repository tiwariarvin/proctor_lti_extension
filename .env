PORT=3000
PUBLIC_BASE_URL=https://your-tool-host.example.com

# From Brightspace: Manage Extensibility → LTI Advantage → your tool registration
PLATFORM_ISSUER=https://yourinstance.brightspace.com
PLATFORM_OIDC_AUTH_URL=https://yourinstance.brightspace.com/d2l/lti/authenticate
PLATFORM_JWKS_URI=https://yourinstance.brightspace.com/d2l/.well-known/jwks
LTI_CLIENT_ID=your-brightspace-client-id
# If Brightspace shows a separate OAuth2 Audience, set it here; otherwise omit.
# LTI_TOKEN_AUDIENCE=

# Comma-separated deployment IDs this tool accepts (from Brightspace deployment)
ALLOWED_DEPLOYMENT_IDS=deployment-guid-1,deployment-guid-2

# Optional: used when the launch does not pass custom test_runner_url
DEFAULT_TEST_RUNNER_URL=

# Signs short-lived OIDC state JWTs (HS256); use a long random string in production
SESSION_SECRET=change-me-to-a-long-random-secret
